# ─────────────────────────────────────────────────────────────
# ARABELA · Plataforma de Inteligencia de Cobranza
# Copia este archivo a .env.local y rellena los valores.
# NUNCA subas .env.local a git. El service-role key solo vive en el servidor.
# ─────────────────────────────────────────────────────────────

# URL del proyecto Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon / publishable key — segura para el cliente (RLS la protege)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service-role key — SOLO servidor. Bypassa RLS. Usada por la ingesta
# y el recálculo de métricas. Jamás exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Nombre del bucket de Storage donde se guardan los .xlsx crudos (auditoría)
SUPABASE_STORAGE_BUCKET=raw-campaigns

# (Opcional) OAuth Google — ver §7. Se configura en el dashboard de Supabase,
# aquí no hace falta clave; se deja el hook documentado.
# NEXT_PUBLIC_ENABLE_GOOGLE_OAUTH=false
