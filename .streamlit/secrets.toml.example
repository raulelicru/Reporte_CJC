# Copia a .streamlit/secrets.toml (local) o pégalo en Streamlit Cloud →
# Manage app → Settings → Secrets. NUNCA subas secrets.toml a git.
#
# Cadena de conexión de Neon (Dashboard → Connect → "Connection string",
# preferentemente la POOLED / -pooler). Incluye usuario, password, host y ?sslmode=require.
DATABASE_URL = "postgresql://usuario:password@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"
